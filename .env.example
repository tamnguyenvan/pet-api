# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Supabase runtime
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Drizzle migrations
DATABASE_URL=

# Admin bootstrap
# Comma-separated emails that can invite admins and manage all RAG uploads.
SUPER_ADMIN_EMAILS=
# Comma-separated emails that should receive admin access after signing in with Clerk.
ADMIN_EMAILS=

# OpenAI-compatible provider for RAG
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_CHAT_MODEL=gpt-4o-mini
OPENAI_COMPATIBLE_EMBEDDING_MODEL=text-embedding-3-small

# RAG uploads
RAG_UPLOADS_BUCKET=rag-uploads
